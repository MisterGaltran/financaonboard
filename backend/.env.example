# ==== Server ====
PORT=4000
NODE_ENV=development

# ==== CORS — origem permitida do frontend ====
FRONTEND_URL=http://localhost:5173

# ==== Provedores REST ====
FINNHUB_API_KEY=your_finnhub_key_here
EODHD_API_KEY=your_eodhd_key_here

# ==== Polygon (WebSocket streaming) ====
POLYGON_API_KEY=your_polygon_key_here
POLYGON_WS_URL=wss://socket.polygon.io/stocks

# ==== Cron (agenda econômica refresh) ====
CALENDAR_REFRESH_CRON=*/5 * * * *

# ==== Brasil (BRAPI + RSS) ====
# BRAPI_API_KEY opcional — free tier funciona sem token com rate limit menor
# Registre-se grátis em https://brapi.dev/dashboard
BRAPI_API_KEY=
# Tickers B3 monitorados (vazio = usa lista default do código)
BR_TICKERS=
# Intervalo de pool dos RSS brasileiros (ms)
BR_RSS_POLL_INTERVAL_MS=90000

# ==== Rate limiting ====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
